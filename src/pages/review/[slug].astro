---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StarRating from '../../components/StarRating.astro';
import CTAButton from '../../components/CTAButton.astro';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

const { review } = Astro.props;
const { Content } = await review.render();

const siteUrl = import.meta.env.SITE || 'https://yourdomain.com';
const pageUrl = `${siteUrl}/review/${review.slug}/`;
const casinoName = review.data.title.split(':')[0].trim();

const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'Review',
  name: review.data.title,
  reviewBody: review.data.metaDescription,
  reviewRating: {
    '@type': 'Rating',
    ratingValue: review.data.overallRating,
    bestRating: 5,
    worstRating: 1,
  },
  author: {
    '@type': 'Organization',
    name: '12B SPORTS',
    url: siteUrl,
  },
  itemReviewed: {
    '@type': 'Product',
    name: casinoName,
    url: `${siteUrl}/go/${review.data.affiliateLinkId}/`,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'รีวิว', item: `${siteUrl}/review/` },
    { '@type': 'ListItem', position: 3, name: casinoName, item: pageUrl },
  ],
};

const schema = [reviewSchema, breadcrumbSchema];
---

<Base
  title={review.data.seoTitle}
  description={review.data.metaDescription}
  canonicalUrl={pageUrl}
  schema={schema}
>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-text-muted mb-8" aria-label="breadcrumb">
      <a href="/" class="hover:text-cta transition-colors">หน้าแรก</a>
      <span class="mx-2">/</span>
      <span>รีวิว</span>
      <span class="mx-2">/</span>
      <span class="text-white">{casinoName}</span>
    </nav>

    <!-- Review header card -->
    <div class="bg-bg-card border border-border-card rounded-xl p-6 mb-8">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
        <div>
          {review.data.badgeText && (
            <span class="inline-block bg-badge text-white text-xs font-bold px-3 py-1 rounded-full mb-3">
              {review.data.badgeText}
            </span>
          )}
          <h1 class="text-white text-2xl md:text-3xl font-extrabold mb-2">{casinoName}</h1>
          <div class="flex items-center gap-3 mb-4">
            <StarRating rating={review.data.overallRating} />
            <span class="text-text-muted text-sm">คะแนนรวม</span>
          </div>
          <p class="text-cta font-semibold">{review.data.bonusDescription}</p>
        </div>
        <div class="flex flex-col gap-3 md:min-w-48">
          <CTAButton
            href={`/go/${review.data.affiliateLinkId}/`}
            text={`ไปที่ ${casinoName}`}
            size="md"
            fullWidth={true}
          />
          <p class="text-text-muted text-xs text-center">ฝากขั้นต่ำ {review.data.minDeposit}</p>
        </div>
      </div>

      <!-- Quick facts -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6 pt-6 border-t border-border-card">
        <div>
          <p class="text-text-muted text-xs mb-1">ฝากขั้นต่ำ</p>
          <p class="text-white font-medium text-sm">{review.data.minDeposit}</p>
        </div>
        <div>
          <p class="text-text-muted text-xs mb-1">จำนวนเกม</p>
          <p class="text-white font-medium text-sm">{review.data.gameCount}</p>
        </div>
        <div>
          <p class="text-text-muted text-xs mb-1">ช่องทางชำระเงิน</p>
          <p class="text-white font-medium text-sm">{review.data.paymentMethods.slice(0, 2).join(', ')}</p>
        </div>
        <div>
          <p class="text-text-muted text-xs mb-1">รองรับภาษา</p>
          <p class="text-white font-medium text-sm">{review.data.supportLanguages.join(', ')}</p>
        </div>
      </div>
    </div>

    <!-- Review body content -->
    <article class="prose-casino">
      <Content />
    </article>

    <!-- Bottom CTA -->
    <div class="mt-12 bg-bg-card border border-cta/30 rounded-xl p-6 text-center">
      <p class="text-white font-bold text-lg mb-2">พร้อมเริ่มเล่นที่ {casinoName}?</p>
      <p class="text-text-muted mb-4">{review.data.bonusDescription}</p>
      <CTAButton
        href={`/go/${review.data.affiliateLinkId}/`}
        text={`รับโบนัสต้อนรับที่ ${casinoName}`}
        size="lg"
        fullWidth={false}
      />
      <p class="text-text-muted text-xs mt-3">18+ เท่านั้น | เดิมพันอย่างรับผิดชอบ</p>
    </div>
  </div>
</Base>
