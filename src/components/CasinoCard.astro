---
import StarRating from './StarRating.astro';
import CTAButton from './CTAButton.astro';

interface Props {
  slug: string;
  title: string;
  overallRating: number;
  bonusDescription: string;
  minDeposit: string;
  paymentMethods: string[];
  gameCount: string;
  affiliateLinkId: string;
  badgeText?: string;
  rank: number;
}

const {
  slug,
  title,
  overallRating,
  bonusDescription,
  minDeposit,
  paymentMethods,
  gameCount,
  affiliateLinkId,
  badgeText,
  rank,
} = Astro.props;

const casinoName = title.split(':')[0].trim();
const affiliateUrl = `/go/${affiliateLinkId}/`;
---

<div class:list={[
  'bg-bg-card border border-border-card rounded-xl p-5 flex flex-col gap-4 relative',
  rank === 1 && 'border-cta/40 shadow-lg shadow-cta/10',
]}>
  {badgeText && (
    <span class="absolute -top-3 left-4 bg-badge text-white text-xs font-bold px-3 py-1 rounded-full">
      {badgeText}
    </span>
  )}

  <!-- Header row -->
  <div class="flex items-start justify-between gap-4 mt-1">
    <div class="flex items-center gap-3">
      <span class="text-text-muted text-sm font-medium w-6">#{rank}</span>
      <div>
        <h2 class="text-white font-bold text-lg leading-tight">{casinoName}</h2>
        <div class="mt-1">
          <StarRating rating={overallRating} />
        </div>
      </div>
    </div>
    <CTAButton href={affiliateUrl} text="เล่นเลย" size="sm" />
  </div>

  <!-- Bonus highlight -->
  <div class="bg-bg-primary rounded-lg px-4 py-3">
    <p class="text-text-muted text-xs uppercase tracking-wide mb-1">โบนัสต้อนรับ</p>
    <p class="text-cta font-semibold text-sm">{bonusDescription}</p>
  </div>

  <!-- Details grid -->
  <div class="grid grid-cols-2 gap-3 text-sm">
    <div>
      <p class="text-text-muted text-xs mb-1">ฝากขั้นต่ำ</p>
      <p class="text-white font-medium">{minDeposit}</p>
    </div>
    <div>
      <p class="text-text-muted text-xs mb-1">จำนวนเกม</p>
      <p class="text-white font-medium">{gameCount}</p>
    </div>
  </div>

  <!-- Payment methods -->
  <div>
    <p class="text-text-muted text-xs mb-2">ช่องทางชำระเงิน</p>
    <div class="flex flex-wrap gap-1">
      {paymentMethods.map((method) => (
        <span class="bg-bg-primary text-text-muted text-xs px-2 py-1 rounded">
          {method}
        </span>
      ))}
    </div>
  </div>

  <!-- Read review link -->
  <a
    href={`/review/${slug}/`}
    class="text-cta hover:text-cta-hover text-sm transition-colors text-center"
  >
    อ่านรีวิวฉบับเต็ม →
  </a>
</div>
