---
import CasinoCard from './CasinoCard.astro';
import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews', ({ data }) => data.showOnHomepage);
const sorted = allReviews.sort((a, b) => a.data.homepageOrder - b.data.homepageOrder);
---

<section class="max-w-6xl mx-auto px-4 py-10">
  <div class="mb-8 text-center">
    <h2 class="text-white text-2xl font-bold mb-2">คาสิโนออนไลน์ที่ดีที่สุดในไทย 2026</h2>
    <p class="text-text-muted">จัดอันดับโดยทีมผู้เชี่ยวชาญ 12B SPORTS จากการทดสอบจริง</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {sorted.map((review) => (
      <CasinoCard
        slug={review.slug}
        title={review.data.title}
        overallRating={review.data.overallRating}
        bonusDescription={review.data.bonusDescription}
        minDeposit={review.data.minDeposit}
        paymentMethods={review.data.paymentMethods}
        gameCount={review.data.gameCount}
        affiliateLinkId={review.data.affiliateLinkId}
        badgeText={review.data.badgeText}
        rank={review.data.homepageOrder}
      />
    ))}
  </div>
</section>
