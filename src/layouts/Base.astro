---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  schema?: object;
}

const { title, description, canonicalUrl, schema } = Astro.props;
const siteUrl = import.meta.env.SITE || 'https://yourdomain.com';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body class="bg-bg-primary min-h-screen flex flex-col">
  <!-- Header -->
  <header class="border-b border-border-card sticky top-0 z-50 bg-bg-primary/95 backdrop-blur">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-white font-bold text-xl hover:text-cta transition-colors">
        12B SPORTS
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm">
        <a href="/" class="text-text-muted hover:text-white transition-colors">หน้าแรก</a>
        <a href="/review/12bet/" class="text-text-muted hover:text-white transition-colors">รีวิว 12BET</a>
        <a href="/12b-sports/" class="text-text-muted hover:text-white transition-colors">12B SPORTS</a>
        <a href="/how-we-rate/" class="text-text-muted hover:text-white transition-colors">วิธีการประเมิน</a>
        <a href="/responsible-gambling/" class="text-text-muted hover:text-white transition-colors">เดิมพันอย่างรับผิดชอบ</a>
      </nav>
      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-text-muted hover:text-white p-2"
        aria-label="เปิดเมนู"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-border-card">
      <nav class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-3 text-sm">
        <a href="/" class="text-text-muted hover:text-white transition-colors">หน้าแรก</a>
        <a href="/review/12bet/" class="text-text-muted hover:text-white transition-colors">รีวิว 12BET</a>
        <a href="/12b-sports/" class="text-text-muted hover:text-white transition-colors">12B SPORTS</a>
        <a href="/how-we-rate/" class="text-text-muted hover:text-white transition-colors">วิธีการประเมิน</a>
        <a href="/responsible-gambling/" class="text-text-muted hover:text-white transition-colors">เดิมพันอย่างรับผิดชอบ</a>
      </nav>
    </div>
  </header>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-border-card mt-16">
    <div class="max-w-6xl mx-auto px-4 py-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
        <div>
          <h3 class="text-white font-semibold mb-3">12B SPORTS</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            พันธมิตรสื่อกีฬาอย่างเป็นทางการของ 12BET ให้ข้อมูลการเดิมพันออนไลน์สำหรับนักเดิมพันไทย
          </p>
        </div>
        <div>
          <h3 class="text-white font-semibold mb-3">ลิงก์ด่วน</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/review/12bet/" class="text-text-muted hover:text-cta transition-colors">รีวิว 12BET</a></li>
            <li><a href="/12b-sports/" class="text-text-muted hover:text-cta transition-colors">12B SPORTS คืออะไร</a></li>
            <li><a href="/how-we-rate/" class="text-text-muted hover:text-cta transition-colors">วิธีการประเมิน</a></li>
            <li><a href="/responsible-gambling/" class="text-text-muted hover:text-cta transition-colors">เดิมพันอย่างรับผิดชอบ</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-white font-semibold mb-3">คำเตือน</h3>
          <p class="text-text-muted text-sm leading-relaxed">
            สำหรับผู้มีอายุ 18 ปีขึ้นไปเท่านั้น เดิมพันอย่างรับผิดชอบ การพนันอาจก่อให้เกิดการติด
          </p>
          <p class="text-text-muted text-sm mt-2">
            ขอความช่วยเหลือ: สายด่วนสุขภาพจิต <strong class="text-white">1323</strong>
          </p>
        </div>
      </div>
      <div class="border-t border-border-card pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-text-muted text-xs">
          © 2026 12B SPORTS. เนื้อหาบนเว็บไซต์นี้มีวัตถุประสงค์เพื่อให้ข้อมูลเท่านั้น
        </p>
        <p class="text-text-muted text-xs">
          เว็บไซต์นี้อาจได้รับค่าคอมมิชชั่นเมื่อคุณสมัครสมาชิกผ่านลิงก์ของเรา
        </p>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
